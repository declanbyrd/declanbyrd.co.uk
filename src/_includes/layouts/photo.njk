{% extends 'layouts/base.njk' %}

{% block content %}

  <section>
    <article>
      <div class="[ flex-row ]">
        <h2>Photos</h2>
        <time class="[ date ]" datetime="{{ page.date | htmlDateTime }}">{{page.date | dateDisplay}}</time>
      </div>
      {{ content | safe }}
      {% for item in photo %}
        <img class="[ large-photo ]" src="{{item.url}}" alt="{{item.alt}}">
      {% endfor %}
    </article>
  </section>
  <section class="webmentions-container">
    {% set webmentionUrl %}{{ page.url | url | absoluteUrl(site.url) }}{% endset %}
    {% include 'webmentionlist.njk' %}
    <button class='[ return-button ]'>
      <a href=" /photos">&larr; Return to the photos page</a>
    </button>
  </section>

{% endblock %}